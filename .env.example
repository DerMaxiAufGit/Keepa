# Required
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=                        # For dev mode (guild-scoped commands)

# Database (PostgreSQL)
# Local/bare-metal: use localhost
# Docker Compose:   use "postgres" (the service name) instead of "localhost"
DATABASE_URL=postgresql://keepa:<your-password>@localhost:5432/keepa
POSTGRES_PASSWORD=               # Set a strong password here (used by docker-compose)

# Optional Features
LOG_LEVEL=info                   # error | warn | info | debug
PHISHING_LIST_URL=https://raw.githubusercontent.com/nikolaischunk/discord-phishing-links/main/domain-list.json

# Presence
BOT_STATUS=online                # online | idle | dnd
BOT_ACTIVITY=Keeping the server safe
