# Required
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=                        # For dev mode (guild-scoped commands)

# Database (PostgreSQL)
DATABASE_URL=postgresql://keepa:CHANGE_ME@localhost:5432/keepa
POSTGRES_PASSWORD=CHANGE_ME      # Used by docker-compose for the DB container

# Optional Features
LOG_LEVEL=info                   # error | warn | info | debug
PHISHING_LIST_URL=https://raw.githubusercontent.com/nikolaischunk/discord-phishing-links/main/domain-list.json

# Presence
BOT_STATUS=online                # online | idle | dnd
BOT_ACTIVITY=Keeping the server safe
